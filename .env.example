# ============================================================================
# 自媒体账号内容数据分析系统 - 环境变量配置模板
# 复制本文件为 .env 并填入真实密钥，.env 不会提交到 Git
# ============================================================================

# --- DeepSeek API 配置（核心：用于 AI 智能对话）---
# 前往 https://platform.deepseek.com/api_keys 创建 API Key
LLM_API_KEY=your_deepseek_api_key_here

# API 端点（不要加 /v1 前缀！DeepSeek 不使用 OpenAI 的 /v1 路径）
LLM_API_URL=https://api.deepseek.com/chat/completions

# 模型名称（推荐 deepseek-v4-flash，deepseek-chat 将于 2026/07/24 弃用）
LLM_MODEL=deepseek-v4-flash

# API 请求超时时间（秒）
LLM_TIMEOUT=30

# --- B站真实API配置（可选，用于获取真实UP主数据）---
# 如需从B站获取真实数据，配置以下认证信息
# BILIBILI_SESSDATA=your_sessdata_here

# --- 日志级别（可选）---
# DEBUG 可查看 API 原始响应，用于排查问题
# LOG_LEVEL=INFO
