# ===========================================
# 自媒体账号内容数据分析系统 - 环境变量配置
# 复制本文件为 .env 并填入真实密钥
# .env 不会提交到 Git（已在 .gitignore 中）
# ===========================================

# --- DeepSeek API 配置（AI 对话功能必填）---
#
# 🔑 获取 API Key 步骤：
#   1. 打开 https://platform.deepseek.com/api_keys
#   2. 注册/登录 DeepSeek 账号
#   3. 点击 "创建 API Key"
#   4. 复制生成的 sk-xxx 密钥填入下方
#
# ⚠️ 不配置 LLM_API_KEY 时，系统自动降级为本地统计模式
#    （仍能做数据分析和图表，但没有 AI 智能对话）
#
LLM_API_KEY=your_deepseek_api_key_here

# API 端点（无需修改，DeepSeek 正确端点）
# 注意：没有 /v1 前缀！这与 OpenAI 不同
LLM_API_URL=https://api.deepseek.com/chat/completions

# 模型名称：
#   deepseek-v4-flash  → 快速响应，性价比高（推荐）
#   deepseek-v4-pro    → 更强推理能力，支持思考模式
#   deepseek-chat      → ⚠️ 将于 2026/07/24 弃用
LLM_MODEL=deepseek-v4-flash

# API 请求超时时间（秒）
LLM_TIMEOUT=30

# --- B站真实API配置（可选）---
# 如需从B站获取真实UP主视频数据，配置 SESSDATA
# BILIBILI_SESSDATA=your_sessdata_here

# --- 日志级别（可选）---
# 设为 DEBUG 可查看完整的 API 请求/响应日志（排查问题时有用）
# LOG_LEVEL=INFO
