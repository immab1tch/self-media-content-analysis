# ============================================================================
# 大模型 API 密钥配置模板
# 复制本文件为 .env 并填入真实密钥，.env 不会提交到 Git
# ============================================================================

# 腾讯云 / Q Cloud 大模型 API
QCLOUD_API_KEY=your_qcloud_api_key_here
QCLOUD_API_BASE_URL=https://your-qcloud-endpoint.example.com/v1

# Workbody 大模型 API
WORKBODY_API_KEY=your_workbody_api_key_here
WORKBODY_API_BASE_URL=https://your-workbody-endpoint.example.com/v1

# DeepSeek 大模型 API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1

# 默认使用的模型提供商（qcloud / workbody / deepseek）
DEFAULT_LLM_PROVIDER=deepseek

# 默认模型名称
DEFAULT_MODEL_NAME=deepseek-chat

# API 请求超时时间（秒）
API_TIMEOUT=30
